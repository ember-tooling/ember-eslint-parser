{
  "name": "gjs-types-test",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:check": "pnpm run /test:check:.*/",
    "test:check:lint-errors": "CHECK_LINT_ERRORS=true eslint . --max-warnings=0 --format compact | egrep '^[0-9]+ problem[s]*' | wc -l | grep -q 1",
    "test:check:with-allow-js": "eslint . --max-warnings=0",
    "test:check:project-service": "PROJECT_SERVICE=true eslint . --max-warnings=0",
    "test:check:project-service:alternate": "PROJECT_SERVICE=true DEFAULT_PROJECT=tsconfig.nojs.json eslint . --max-warnings=0",
    "test:check:project": "PROJECT=tsconfig.json TSCONFIG_ROOT_DIR=$(pwd) eslint . --max-warnings=0",
    "test:check:project:alternate": "PROJECT=tsconfig.nojs.json eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/eslint-parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "ember-eslint-parser": "workspace:*",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-ember": "^13.0.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "typescript": "^6.0.0"
  }
}
