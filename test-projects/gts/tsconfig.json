{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["ES2018", "DOM"],
    "module": "commonjs",
    "experimentalDecorators": true,
    "rootDir": ".",
    "allowJs": true,
    "strictNullChecks": true
  },
  "glint": {
    "environment": "ember-template-imports"
  },
  "include": ["**/*.ts", "**/*.gts", "index.d.ts"]
}
